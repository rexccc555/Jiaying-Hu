# =============================================================================
# 本地开发专用（复制本文件为 .env.local 后填写；.env.local 已在 .gitignore，不会进 Git）
# 一键生成：npm run env:local
# Netlify 上的环境变量不要动；这里只影响你本机 npm run dev。
#
# 注意：Prisma CLI 默认只读 .env，不读 .env.local。数据库操作用：
#   npm run db:migrate   （或 db:push / db:studio）
# =============================================================================

# --- 智能行程（与线上一致即可在本地测 /api/generate）---
OPENAI_API_KEY=
OPENAI_BASE_URL=
# 网关常用 gpt-5.4；未设 OPENAI_MODEL 时代码默认 gpt-5.4,gpt-4o-mini 依次尝试
OPENAI_MODEL=gpt-5.4
# OPENAI_MODEL=gpt-5.4,gpt-4o,gpt-4o-mini
# OPENAI_RESPONSE_FORMAT_JSON=0
OPENAI_DEBUG=1
# OPENAI_TIMEOUT_MS=120000
OPENAI_SKIP_OFFICIAL_URL_CHECK=1

# --- 登录会话签名（至少 16 字符；生产环境必填，否则无法签发 Cookie）---
SESSION_SECRET=please-change-to-a-long-random-string-at-least-16

# --- PostgreSQL（本地与 Netlify 生产均使用；SQLite 文件无法在 Netlify 持久保存）---
# 示例：Neon / Supabase / 本机 Docker Postgres。须带 sslmode=require（云厂商常见）。
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/takeadayoff?schema=public"

# --- 可选：本地 canonical / 绝对链接（不设则用 layout 里默认生产域名）---
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
