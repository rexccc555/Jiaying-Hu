generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String
  phone        String?
  createdAt    DateTime    @default(now())
  savedTrips   SavedTrip[]
}

model SavedTrip {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locale    String
  payload   String
  createdAt DateTime @default(now())

  @@index([userId])
}
